    replacement_infos {
      original_chunk {
        target_content: "  const [activeVehicleId, setActiveVehicleId] = useState<string>(() => {\n    const cached = localStorage.getItem(\'volt_active_vehicle_id\');\n    return cached || \'tesla-3\';\n  });\n\n  const [config, setConfig] = useState<CostAssumptions>(() => {\n    const cached = localStorage.getItem(\'volt_config\');\n    return cached ? JSON.parse(cached) : INITIAL_ASSUMPTIONS;\n  });\n\n  // Keep localStorage up to date\n  useEffect(() => {\n    localStorage.setItem(\'volt_vehicles\', JSON.stringify(vehicles));\n  }, [vehicles]);\n\n  useEffect(() => {\n    localStorage.setItem(\'volt_sessions\', JSON.stringify(sessions));\n  }, [sessions]);\n\n  useEffect(() => {\n    localStorage.setItem(\'volt_active_vehicle_id\', activeVehicleId);\n  }, [activeVehicleId]);\n\n  useEffect(() => {\n    localStorage.setItem(\'volt_config\', JSON.stringify(config));\n  }, [config]);\n\n  // Find active vehicle details\n  const activeVehicle = vehicles.find(v => v.id === activeVehicleId) || vehicles[0];\n\n  // Action: Add Session Logger Record\n  const handleAddSession = (newSession: ChargingSession) => {\n    setSessions(prev => [newSession, ...prev]);\n    \n    // Automatically update Odometer on adding session if applicable\n    setVehicles(prevVehs => prevVehs.map(veh => {\n      if (veh.id === newSession.vehicleId) {\n        // Approximate added km based on loaded kWh energy\n        const addedKm = Math.round(newSession.energyKwh / (veh.efficiency / 1000));\n        return {\n          ...veh,\n          odometer: veh.odometer + addedKm,\n          batterySoC: Math.min(100, veh.batterySoC + 20) // top up SoC simulated\n        };\n      }\n      return veh;\n    }));\n\n    setCurrentTab(\'activity\');\n  };\n\n  // Action: Delete Session Log\n  const handleDeleteSession = (id: string) => {\n    setSessions(prev => prev.filter(s => s.id !== id));\n  };\n\n  // Action: Add custom registered Vehicle\n  const handleAddVehicle = (newVehicle: Vehicle) => {\n    setVehicles(prev => [...prev, newVehicle]);\n    setActiveVehicleId(newVehicle.id);\n  };\n\n  // Action: De-register vehicle\n  const handleDeleteVehicle = (id: string) => {\n    setVehicles(prev => prev.filter(v => v.id !== id));\n    // Fall back to tesla\n    setActiveVehicleId(\'tesla-3\');\n  };\n\n  // Reset entire activity logs\n  const handleClearSessions = () => {\n    localStorage.removeItem(\'volt_sessions\');\n    localStorage.removeItem(\'volt_vehicles\');\n    localStorage.removeItem(\'volt_config\');\n    setSessions([]);\n    setVehicles(INITIAL_VEHICLES);\n    setConfig(INITIAL_ASSUMPTIONS);\n    setActiveVehicleId(\'tesla-3\');\n  };"
        replacement_content: "  const [activeVehicleId, setActiveVehicleId] = useState<string>(() => {\n    const cached = localStorage.getItem(\'volt_active_vehicle_id\');\n    return cached || \'tata-nexon\';\n  });\n\n  const [config, setConfig] = useState<CostAssumptions>(() => {\n    const cached = localStorage.getItem(\'volt_config\');\n    return cached ? JSON.parse(cached) : INITIAL_ASSUMPTIONS;\n  });\n\n  // Keep localStorage up to date\n  useEffect(() => {\n    localStorage.setItem(\'volt_vehicles\', JSON.stringify(vehicles));\n  }, [vehicles]);\n\n  useEffect(() => {\n    localStorage.setItem(\'volt_sessions\', JSON.stringify(sessions));\n  }, [sessions]);\n\n  useEffect(() => {\n    localStorage.setItem(\'volt_active_vehicle_id\', activeVehicleId);\n  }, [activeVehicleId]);\n\n  useEffect(() => {\n    localStorage.setItem(\'volt_config\', JSON.stringify(config));\n  }, [config]);\n\n  // Find active vehicle details\n  const activeVehicle = vehicles.find(v => v.id === activeVehicleId) || vehicles[0];\n\n  // Action: Add Session Logger Record\n  const handleAddSession = (newSession: ChargingSession) => {\n    setSessions(prev => [newSession, ...prev]);\n    \n    // Automatically update Odometer on adding session if applicable\n    setVehicles(prevVehs => prevVehs.map(veh => {\n      if (veh.id === newSession.vehicleId) {\n        // Use exact captured odometer reading if entered, else estimate\n        const finalOdometer = newSession.odometerReading || (veh.odometer + Math.round(newSession.energyKwh / (veh.efficiency / 1000)));\n        // Exact SoC added based on battery capacity\n        const addedSoC = Math.round((newSession.energyKwh / veh.batteryCapacity) * 100);\n        return {\n          ...veh,\n          odometer: finalOdometer,\n          batterySoC: Math.min(100, veh.batterySoC + addedSoC)\n        };\n      }\n      return veh;\n    }));\n\n    setCurrentTab(\'activity\');\n  };\n\n  // Action: Delete Session Log\n  const handleDeleteSession = (id: string) => {\n    setSessions(prev => prev.filter(s => s.id !== id));\n  };\n\n  // Action: Add custom registered Vehicle\n  const handleAddVehicle = (newVehicle: Vehicle) => {\n    setVehicles(prev => [...prev, newVehicle]);\n    setActiveVehicleId(newVehicle.id);\n  };\n\n  // Action: De-register vehicle\n  const handleDeleteVehicle = (id: string) => {\n    setVehicles(prev => prev.filter(v => v.id !== id));\n    // Fall back to Nexon EV\n    setActiveVehicleId(\'tata-nexon\');\n  };\n\n  // Reset entire activity logs\n  const handleClearSessions = () => {\n    localStorage.removeItem(\'volt_sessions\');\n    localStorage.removeItem(\'volt_vehicles\');\n    localStorage.removeItem(\'volt_config\');\n    setSessions([]);\n    setVehicles(INITIAL_VEHICLES);\n    setConfig(INITIAL_ASSUMPTIONS);\n    setActiveVehicleId(\'tata-nexon\');\n  };"
