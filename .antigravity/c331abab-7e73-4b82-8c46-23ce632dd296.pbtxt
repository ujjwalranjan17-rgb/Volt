  file_change {
    absolute_path_uri: "file:///src/components/Vehicles.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import React, { useState } from \'react\';\nimport { SyncIcon } from \'lucide-react\'; // Wait, let\'s use standard icons from lucide-react: RefreshCw, Compass, Plus, Sliders, ChevronRight, CheckCircle2, Search, Zap, Trash2, ArrowLeft, PlusCircle } from \'lucide-react\';\nimport { \n  RefreshCw, Outbox, Sliders, ChevronRight, CheckCircle, Search, Zap, Trash2, ArrowLeft, PlusCircle, \n  Battery, Leaf, Sparkles, Navigation, Dumbbell, AlertTriangle \n} from \'lucide-react\';\nimport { Vehicle } from \'../types\';\n\ninterface VehiclesProps {\n  vehicles: Vehicle[];\n  activeVehicle: Vehicle;\n  onSelectVehicle: (id: string) => void;\n  onAddVehicle: (newVehicle: Vehicle) => void;\n  onDeleteVehicle: (id: string) => void;\n  onNavigateToSettings: () => void;\n}\n\nexport default function Vehicles({ \n  vehicles, \n  activeVehicle, \n  onSelectVehicle, \n  onAddVehicle, \n  onDeleteVehicle,\n  onNavigateToSettings\n}: VehiclesProps) {\n  const [isAdding, setIsAdding] = useState(false);\n  const [searchQuery, setSearchQuery] = useState(\'\');\n  const [syncing, setSyncing] = useState(false);\n  const [syncMessage, setSyncMessage] = useState<string | null>(null);\n\n  // Form State for Manual Custom Adding\n  const [manualBrand, setManualBrand] = useState(\'Tesla\');\n  const [manualModel, setManualModel] = useState(\'\');\n  const [manualTrim, setManualTrim] = useState(\'Standard Range Plus\');\n  const [manualRange, setManualRange] = useState(380);\n  const [manualCapacity, setManualCapacity] = useState(60);\n  const [manualEfficiency, setManualEfficiency] = useState(130);\n\n  // Trigger simulated force synchronization\n  const handleForceSync = () => {\n    setSyncing(true);\n    setSyncMessage(null);\n    setTimeout(() => {\n      setSyncing(false);\n      setSyncMessage(\'Vehicle synced successfully\');\n      setTimeout(() => setSyncMessage(null), 3000);\n    }, 1500);\n  };\n\n  // Pre-seed brands\n  const QUICK_BRANDS = [\n    { name: \'Tesla\', icon: <Zap className=\"w-6 h-6 text-primary\" /> },\n    { name: \'Tata\', icon: <BoltIcon className=\"w-6 h-6 text-primary\" /> }, // Wait, let\'s use native Zap/Battery \n    { name: \'MG\', icon: <Battery className=\"w-6 h-6 text-secondary\" /> },\n    { name: \'Hyundai\', icon: <CompassIcon className=\"w-6 h-6 text-primary-fixed\" /> }\n  ];\n\n  function BoltIcon(props: any) {\n    return (\n      <svg {...props} xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"2\" strokeLinecap=\"round\" strokeLinejoin=\"round\"><path d=\"m13 2-2 10h9L9 22l2-10H3L13 2z\"/></svg>\n    )\n  }\n\n  function CompassIcon(props: any) {\n    return (\n      <svg {...props} xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"2\" strokeLinecap=\"round\" strokeLinejoin=\"round\"><circle cx=\"12\" cy=\"12\" r=\"10\"/><polygon points=\"16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76\"/></svg>\n    )\n  }\n\n  // Predefined popular list\n  const POPULAR_LIST = [\n    { name: \'Kia\', model: \'EV6 GT\' },\n    { name: \'BYD\', model: \'Atto 3\' },\n    { name: \'Audi\', model: \'e-tron Sportback\' }\n  ];\n\n  const handleCreateVehicle = (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!manualModel) return;\n\n    const brandSlug = manualBrand.toLowerCase();\n    const id = `${brandSlug}-${Date.now()}`;\n    \n    // Choose starting simulated image based on selected brand\n    let img = \'https://lh3.googleusercontent.com/aida-public/AB6AXuBpJ0OEJLRm4eXKrvhqGucTJjNt-_szYOf0OWMog0ZsNRHzIiQav0wiVXQ4jP-t3fGdHUUTELNY8mQlcXMv0tva5eXN9EbZ_D3BmwgklPKNXfuogOql5oF1uzIlVIqJgOa2sBHV1fec2eVFOaR-Tj2Fhh16da44AbjvostUeZ8EljMxcUJUfL38sV_mEh4MnJYPQglCadrGFvuj2chz-4v0bFw3B_EQKQoYyBwFVWlUxU-3fCFKwSaFRGxw5ryyWGdysoxP8Y-WWdCf\'; // Tesla\n    if (brandSlug === \'tata\') {\n      img = \'https://lh3.googleusercontent.com/aida-public/AB6AXuBc3P10Pz7obg5vaNiZzt1Rj0CBt0gzv3whgs3OOBHK7smxCx6UlzF7xL-Dox281JrxQ4lM0zv-brYb5qZUhz6KOdD_WNMq4el8f0-IfK7mbMjFG6BAIjKuPAoe35f8YnU8p4FIuAS-GNCkbA6qDJWjM_2SXRvjlYiYHslGxdKYq_3H5i-DXgNAkVJfHFPHsmXMs8Vx5cW8mLg1P_GHeb1RuGxxcXpgmu2DRhQIIRWeOVj0vjuz-Ufncp65IgE2s0ZQ4APofLULqtOi\';\n    } else if (brandSlug === \'mg\') {\n      img = \'https://lh3.googleusercontent.com/aida-public/AB6AXuAjdXUvJmojBrzBHyIdRq9z_-NmByzmVm1HYmsdSl9mk4WCaNF4_SjtDnO1d5BDZLOnYlbSzGZc2In42imfpN4_PnaHfc_B1c8Uurb5Ek4B6TFy80l6hxZ2QVH3duYnVb6HBKldO_Ek-1HCehQ-tst_W2qhTvbS4i8H1GOM_s4LW9Iey5ssoOpH1BUobq414-Lmhj6xpSGKlg7CU10ig0dopkdScjeq6pSNsoZKf7bbw3JsKcmWqY9eQ13I7tuKjVyCgA9Ds6z2MR3M\';\n    }\n\n    const created: Vehicle = {\n      id,\n      brand: manualBrand,\n      model: manualModel,\n      trim: manualTrim,\n      image: img,\n      statusText: \'Registered \342\200\242 Fully Connected\',\n      range: manualRange,\n      batteryCapacity: manualCapacity,\n      batterySoC: 90, // Defaults nicely\n      efficiency: manualEfficiency,\n      odometer: 100 // raw fresh EV!\n    };\n\n    onAddVehicle(created);\n    setIsAdding(false);\n    // Reset Form\n    setManualModel(\'\');\n    setManualTrim(\'Standard Range Plus\');\n  };\n\n  // Filter list by simple query\n  const filteredPopular = POPULAR_LIST.filter(item => \n    item.name.toLowerCase().includes(searchQuery.toLowerCase()) || \n    item.model.toLowerCase().includes(searchQuery.toLowerCase())\n  );\n\n  return (\n    <div id=\"vehicles-tab\" className=\"space-y-6\">\n      \n      {/* State A: Add New Vehicle Screen */}\n      {isAdding ? (\n        <div className=\"space-y-6 animate-fade-in\">\n          \n          <div className=\"flex items-center gap-2\">\n            <button \n              onClick={() => setIsAdding(false)}\n              className=\"text-primary hover:bg-surface-variant/40 p-2 rounded-full cursor-pointer transition-colors\"\n            >\n              <ArrowLeft className=\"w-5 h-5\" />\n            </button>\n            <h2 className=\"font-sans text-xl font-bold text-on-surface\">Add Custom Vehicle</h2>\n          </div>\n\n          <form onSubmit={handleCreateVehicle} className=\"space-y-5 bg-surface-container-low border border-outline-variant/30 p-5 rounded-2xl\">\n            \n            <div className=\"grid grid-cols-2 gap-4\">\n              {/* Brand Selector */}\n              <div className=\"flex flex-col gap-1.5\">\n                <label className=\"font-mono text-[10px] font-bold text-on-surface-variant uppercase tracking-wider\">Manufacturer</label>\n                <select \n                  value={manualBrand} \n                  onChange={(e) => setManualBrand(e.target.value)}\n                  className=\"bg-surface-container-high border border-outline-variant/40 text-on-surface text-sm rounded-lg p-2.5 outline-none focus:border-primary/60 transition-colors\"\n                >\n                  <option value=\"Tesla\">Tesla</option>\n                  <option value=\"Tata\">Tata Motors</option>\n                  <option value=\"MG\">MG Motor</option>\n                  <option value=\"Hyundai\">Hyundai</option>\n                  <option value=\"Kia\">Kia</option>\n                  <option value=\"BYD\">BYD</option>\n                </select>\n              </div>\n\n              {/* Model String */}\n              <div className=\"flex flex-col gap-1.5\">\n                <label className=\"font-mono text-[10px] font-bold text-on-surface-variant uppercase tracking-wider\">Model Name</label>\n                <input \n                  type=\"text\" \n                  value={manualModel}\n                  onChange={(e) => setManualModel(e.target.value)}\n                  placeholder=\"e.g. Model Y, Nexon Max\"\n                  required\n                  className=\"bg-surface-container-high border border-outline-variant/40 text-on-surface text-sm rounded-lg p-2.5 outline-none focus:border-primary/60 placeholder-on-surface-variant/30 transition-colors\"\n                />\n              </div>\n            </div>\n\n            {/* Range / Trim */}\n            <div className=\"flex flex-col gap-1.5\">\n              <label className=\"font-mono text-[10px] font-bold text-on-surface-variant uppercase tracking-wider\">Trim Level</label>\n              <input \n                type=\"text\" \n                value={manualTrim}\n                onChange={(e) => setManualTrim(e.target.value)}\n                placeholder=\"e.g. Performance All-Wheel Drive, Standard Edition\"\n                className=\"bg-surface-container-high border border-outline-variant/40 text-on-surface text-sm rounded-lg p-2.5 outline-none focus:border-primary/60 placeholder-on-surface-variant/30 transition-colors\"\n              />\n            </div>\n\n            <div className=\"grid grid-cols-3 gap-3\">\n              {/* Range km */}\n              <div className=\"flex flex-col gap-1.5\">\n                <label className=\"font-mono text-[9px] font-bold text-on-surface-variant uppercase tracking-wider\">Max Range</label>\n                <input \n                  type=\"number\" \n                  value={manualRange}\n                  onChange={(e) => setManualRange(Number(e.target.value))}\n                  placeholder=\"km\"\n                  className=\"bg-surface-container-high border border-outline-variant/40 text-on-surface text-sm rounded-lg p-2.5 text-right font-mono\"\n                />\n              </div>\n\n              {/* Capacity kWh */}\n              <div className=\"flex flex-col gap-1.5\">\n                <label className=\"font-mono text-[9px] font-bold text-on-surface-variant uppercase tracking-wider\">Battery Cap</label>\n                <input \n                  type=\"number\" \n                  value={manualCapacity}\n                  onChange={(e) => setManualCapacity(Number(e.target.value))}\n                  placeholder=\"kWh\"\n                  className=\"bg-surface-container-high border border-outline-variant/40 text-on-surface text-sm rounded-lg p-2.5 text-right font-mono\"\n                />\n              </div>\n\n              {/* Efficiency Wh/km */}\n              <div className=\"flex flex-col gap-1.5\">\n                <label className=\"font-mono text-[9px] font-bold text-on-surface-variant uppercase tracking-wider\">Efficiency</label>\n                <input \n                  type=\"number\" \n                  value={manualEfficiency}\n                  onChange={(e) => setManualEfficiency(Number(e.target.value))}\n                  placeholder=\"Wh/km\"\n                  className=\"bg-surface-container-high border border-outline-variant/40 text-on-surface text-sm rounded-lg p-2.5 text-right font-mono\"\n                />\n              </div>\n            </div>\n\n            <button \n              type=\"submit\"\n              className=\"w-full bg-primary py-3 rounded-xl text-on-primary font-semibold text-sm hover:bg-primary-fixed-dim transition-all shadow-md active:scale-95\"\n            >\n              Verify & Add Vehicle\n            </button>\n          </form>\n\n          {/* Quick suggestions with search overlay */}\n          <div className=\"space-y-3\">\n            <h3 className=\"font-mono text-[10px] text-primary uppercase tracking-wider pl-1\">Brand Selection Catalog</h3>\n            \n            <div className=\"relative\">\n              <Search className=\"w-4 h-4 text-on-surface-variant absolute left-3.5 top-1/2 -translate-y-1/2\" />\n              <input \n                type=\"text\" \n                placeholder=\"Search standard manufactured specs...\"\n                value={searchQuery}\n                onChange={(e) => setSearchQuery(e.target.value)}\n                className=\"bg-surface-container-high border border-outline-variant/30 rounded-xl py-3 pl-10 pr-4 text-sm text-on-surface placeholder:text-on-surface-variant/40 focus:outline-none w-full\"\n              />\n            </div>\n\n            <div className=\"grid grid-cols-2 gap-3\">\n              {QUICK_BRANDS.map(b => (\n                <button\n                  key={b.name}\n                  type=\"button\"\n                  onClick={() => {\n                    setManualBrand(b.name);\n                    setManualModel(b.name === \'Tesla\' ? \'Model Y\' : b.name === \'Tata\' ? \'Nexon EV EV max\' : b.name === \'MG\' ? \'ZS EV\' : \'Ioniq 6\');\n                  }}\n                  className=\"bg-surface-container-high border border-outline-variant/20 py-3 px-4 rounded-xl flex items-center justify-between text-left hover:border-primary/50 group cursor-pointer\"\n                >\n                  <span className=\"font-sans text-sm font-bold text-on-surface group-hover:text-primary transition-colors\">{b.name}</span>\n                  {b.icon}\n                </button>\n              ))}\n            </div>\n          </div>\n\n        </div>\n      ) : (\n        /* State B: Active Selected Vehicle Details Panel */\n        <div className=\"space-y-6\">\n          \n          {/* Header context selectors block */}\n          <section className=\"space-y-4\">\n            \n            {/* Horizontal switch context lists */}\n            <div className=\"flex gap-2.5 overflow-x-auto pb-1.5 scrollbar-none\">\n              {vehicles.map(v => (\n                <button\n                  key={v.id}\n                  onClick={() => onSelectVehicle(v.id)}\n                  className={`px-3.5 py-1.5 rounded-full text-xs font-bold transition-all shrink-0 cursor-pointer ${\n                    v.id === activeVehicle.id\n                      ? \'bg-primary text-on-primary shadow-sm\'\n                      : \'bg-surface-container-low text-on-surface-variant hover:text-on-surface border border-outline-variant/20\'\n                  }`}\n                >\n                  {v.brand} {v.model}\n                </button>\n              ))}\n              <button\n                onClick={() => setIsAdding(true)}\n                className=\"px-3.5 py-1.5 rounded-full text-xs font-bold border border-dashed border-outline-variant/50 text-primary-fixed hover:border-primary shrink-0 cursor-pointer flex items-center gap-1\"\n              >\n                <PlusCircle className=\"w-3.5\" /> Add Car\n              </button>\n            </div>\n\n            {/* Selected car identification summary */}\n            <div className=\"flex justify-between items-start pt-2\">\n              <div>\n                <h2 className=\"font-sans text-2xl font-bold text-on-surface tracking-tight\">\n                  {activeVehicle.brand} {activeVehicle.model}\n                </h2>\n                <p className=\"font-sans text-xs text-on-surface-variant mt-0.5\">\n                  {activeVehicle.trim}\n                </p>\n              </div>\n\n              <div className=\"inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-primary/10 border border-primary/20 shadow-inner\">\n                <span className=\"w-2 h-2 rounded-full bg-primary animate-pulse\"></span>\n                <span className=\"font-mono text-[10px] text-primary font-bold\">Synced 2m ago</span>\n              </div>\n            </div>\n\n            {/* Image showcase layout */}\n            <div className=\"w-full aspect-video rounded-xl bg-surface-container-high border border-outline-variant/40 overflow-hidden relative shadow-inner group\">\n              <img \n                src={activeVehicle.image} \n                alt={`${activeVehicle.brand} ${activeVehicle.model}`}\n                referrerPolicy=\"no-referrer\"\n                className=\"w-full h-full object-cover object-center mix-blend-luminosity opacity-85 group-hover:scale-105 transition-transform duration-500\"\n              />\n              {/* Bottom linear dark shade cover */}\n              <div className=\"absolute inset-0 bg-gradient-to-t from-surface via-transparent to-transparent opacity-80\"></div>\n              \n              {/* Floating metadata indicator */}\n              <div className=\"absolute bottom-4 left-4 right-4 flex justify-between items-end\">\n                <div className=\"flex flex-col\">\n                  <span className=\"font-mono text-[9px] font-bold text-on-surface-variant uppercase tracking-widest mb-1\">Estimated Range</span>\n                  <div className=\"flex items-baseline gap-1\">\n                    <span className=\"font-mono text-3xl font-bold text-on-surface leading-none\">{activeVehicle.range}</span>\n                    <span className=\"font-mono text-xs font-semibold text-on-surface-variant\">km</span>\n                  </div>\n                </div>\n\n                <div className=\"bg-surface/85 backdrop-blur-sm p-1.5 rounded-lg border border-outline-variant/30 text-[10px] text-on-surface-variant font-mono\">\n                  {activeVehicle.statusText}\n                </div>\n              </div>\n            </div>\n          </section>\n\n          {/* Telemetry Bento Grid layout */}\n          <section className=\"grid grid-cols-2 gap-3\">\n            \n            {/* Sub-panel A: SoC State card */}\n            <div className=\"bg-surface-container-low border border-outline-variant/20 rounded-xl p-4 flex flex-col justify-between aspect-square relative overflow-hidden group\">\n              <div className=\"flex justify-between items-start mb-2 z-10\">\n                <Battery className=\"w-5 h-5 text-secondary\" />\n                <span className=\"font-mono text-[9px] font-bold text-on-surface-variant bg-surface px-2 py-0.5 rounded-sm border border-outline-variant/10\">SoC</span>\n              </div>\n              <div className=\"z-10 mt-auto\">\n                <div className=\"flex items-baseline gap-0.5\">\n                  <span className=\"font-mono text-3xl font-bold text-on-surface leading-none\">\n                    {activeVehicle.batterySoC}\n                  </span>\n                  <span className=\"font-mono text-sm font-semibold text-secondary\">%</span>\n                </div>\n                <div className=\"w-full bg-surface-container-high h-1.5 rounded-full mt-2 overflow-hidden border border-outline-variant/10\">\n                  <div \n                    className=\"bg-secondary h-full rounded-full transition-all duration-500\" \n                    style={{ width: `${activeVehicle.batterySoC}%` }}\n                  ></div>\n                </div>\n              </div>\n\n              {/* Decorative abstract elements overlay matching screenshot */}\n              <div className=\"absolute -bottom-6 -right-6 w-24 h-24 rounded-full border-[10px] border-secondary/10 group-hover:border-secondary/20 transition-colors pointer-events-none\"></div>\n              <div className=\"absolute -bottom-3 -right-3 w-16 h-16 rounded-full border-[6px] border-secondary/15 pointer-events-none\"></div>\n            </div>\n\n            {/* Sub-panel B: Lifetime Efficiency card */}\n            <div className=\"bg-surface-container-low border border-outline-variant/20 rounded-xl p-4 flex flex-col justify-between aspect-square relative overflow-hidden group\">\n              <div className=\"flex justify-between items-start mb-2 z-10\">\n                <Leaf className=\"w-5 h-5 text-primary\" />\n                <span className=\"font-mono text-[9px] font-bold text-on-surface-variant bg-surface px-2 py-0.5 rounded-sm border border-outline-variant/10\">Avg</span>\n              </div>\n              \n              <div className=\"z-10 mt-auto\">\n                <div className=\"flex items-baseline gap-1\">\n                  <span className=\"font-mono text-3xl font-bold text-on-surface leading-none\">\n                    {activeVehicle.efficiency}\n                  </span>\n                  <span className=\"font-mono text-[10px] font-semibold text-primary\">Wh/km</span>\n                </div>\n                <p className=\"text-[10px] text-on-surface-variant mt-1.5\">\n                  Top 15% green ranking\n                </p>\n              </div>\n\n              {/* Abstract miniature SVG trend overlay line */}\n              <svg className=\"absolute bottom-4 right-0 w-full h-12 opacity-25 group-hover:opacity-45 transition-opacity\" preserveAspectRatio=\"none\" viewBox=\"0 0 100 40\">\n                <path d=\"M0,30 Q20,10 40,25 T80,5 T100,20\" fill=\"none\" stroke=\"#4edea3\" strokeWidth=\"2.5\"></path>\n              </svg>\n            </div>\n\n            {/* Sub-panel C: Cumulative Odometer spanning full width */}\n            <div className=\"col-span-2 bg-surface-container-low border border-outline-variant/20 rounded-xl p-4 flex items-center justify-between hover:border-outline-variant/40 transition-all\">\n              <div className=\"flex items-center gap-3\">\n                <div className=\"w-10 h-10 rounded-full bg-surface-container-high border border-outline-variant/20 flex items-center justify-center\">\n                  <Navigation className=\"w-5 h-5 text-on-surface-variant\" />\n                </div>\n                <div className=\"flex flex-col\">\n                  <span className=\"font-sans text-xs text-on-surface-variant\">Total Distance Logged</span>\n                  <div className=\"flex items-baseline gap-1 mt-0.5\">\n                    <span className=\"font-mono text-xl font-bold text-on-surface\">\n                      {activeVehicle.odometer.toLocaleString()}\n                    </span>\n                    <span className=\"font-mono text-[10px] text-on-surface-variant uppercase font-bold\">km</span>\n                  </div>\n                </div>\n              </div>\n\n              <ChevronRight className=\"w-5 h-5 text-on-surface-variant\" />\n            </div>\n            \n          </section>\n\n          {/* Action trigger interactive buttons list */}\n          <section className=\"flex flex-col gap-3 pt-2\">\n            \n            <button \n              onClick={handleForceSync}\n              disabled={syncing}\n              className=\"w-full py-4 rounded-xl bg-primary text-on-primary font-bold text-sm tracking-wide flex items-center justify-center gap-2 hover:bg-primary-fixed-dim transition-all shadow-[0_0_15px_rgba(78,222,163,0.1)] active:scale-[0.98]\"\n            >\n              <RefreshCw className={`w-4 h-4 ${syncing ? \'animate-spin\' : \'\'}`} />\n              <span>{syncing ? \'Synchronizing Telemetry...\' : \'Force Sync Data\'}</span>\n            </button>\n\n            {syncMessage && (\n              <div className=\"flex items-center gap-2 justify-center py-2 bg-primary/10 border border-primary/20 text-primary rounded-lg text-xs font-bold animate-fade-in\">\n                <CheckCircle className=\"w-4 h-4\" />\n                <span>{syncMessage}</span>\n              </div>\n            )}\n\n            <button \n              onClick={onNavigateToSettings}\n              className=\"w-full py-3.5 rounded-xl bg-transparent border border-outline-variant text-on-surface font-semibold text-sm hover:bg-surface-variant/40 transition-all flex items-center justify-center gap-2 active:scale-[0.98]\"\n            >\n              <Sliders className=\"w-4 h-4 text-on-surface\" />\n              <span>Edit Cost Assumptions</span>\n            </button>\n\n            {vehicles.length > 1 && (\n              <button \n                onClick={() => {\n                  if (confirm(`Remove this ${activeVehicle.brand} from active storage?`)) {\n                    onDeleteVehicle(activeVehicle.id);\n                  }\n                }}\n                className=\"w-full py-2.5 bg-error/10 border border-error/20 text-error hover:bg-error hover:text-on-error rounded-xl font-semibold text-xs flex items-center justify-center gap-1.5 transition-colors mt-2 cursor-pointer\"\n              >\n                <Trash2 className=\"w-3.5 h-3.5\" />\n                <span>De-register Vehicle Asset</span>\n              </button>\n            )}\n\n          </section>\n\n        </div>\n      )}\n\n    </div>\n  );\n}\n"
