    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import React, { useState, useEffect } from \'react\';\nimport { \n  Zap, Calendar, Route, EvStation, Sliders, ArrowLeft, PlusCircle, LayoutDashboard, \n  ReceiptText, CarFront, Settings as SettingsIcon, Sparkles, User, LogIn, ChevronRight, CheckCircle2 \n} from \'lucide-react\';\n\n// Types and Seed Values\nimport { Vehicle, ChargingSession, CostAssumptions } from \'./types\';\nimport { INITIAL_VEHICLES, INITIAL_ASSUMPTIONS, INITIAL_SESSIONS } from \'./mockData\';\n\n// Subcomponents\nimport Dashboard from \'./components/Dashboard\';\nimport Activity from \'./components/Activity\';\nimport Vehicles from \'./components/Vehicles\';\nimport LogCharging from \'./components/LogCharging\';\nimport Settings from \'./components/Settings\';\n\nexport default function App() {\n  // Tabs: \'dashboard\' | \'activity\' | \'vehicles\' | \'settings\' | \'log_charging\'\n  const [currentTab, setCurrentTab] = useState<\'dashboard\' | \'activity\' | \'vehicles\' | \'settings\' | \'log_charging\'>(\'dashboard\');\n  \n  // State variables synchronized with standard client side localStorage persistence\n  const [vehicles, setVehicles] = useState<Vehicle[]>(() => {\n    const cached = localStorage.getItem(\'volt_vehicles\');\n    return cached ? JSON.parse(cached) : INITIAL_VEHICLES;\n  });\n\n  const [sessions, setSessions] = useState<ChargingSession[]>(() => {\n    const cached = localStorage.getItem(\'volt_sessions\');\n    return cached ? JSON.parse(cached) : INITIAL_SESSIONS;\n  });\n\n  const [activeVehicleId, setActiveVehicleId] = useState<string>(() => {\n    const cached = localStorage.getItem(\'volt_active_vehicle_id\');\n    return cached || \'tesla-3\';\n  });\n\n  const [config, setConfig] = useState<CostAssumptions>(() => {\n    const cached = localStorage.getItem(\'volt_config\');\n    return cached ? JSON.parse(cached) : INITIAL_ASSUMPTIONS;\n  });\n\n  // Keep localStorage up to date\n  useEffect(() => {\n    localStorage.setItem(\'volt_vehicles\', JSON.stringify(vehicles));\n  }, [vehicles]);\n\n  useEffect(() => {\n    localStorage.setItem(\'volt_sessions\', JSON.stringify(sessions));\n  }, [sessions]);\n\n  useEffect(() => {\n    localStorage.setItem(\'volt_active_vehicle_id\', activeVehicleId);\n  }, [activeVehicleId]);\n\n  useEffect(() => {\n    localStorage.setItem(\'volt_config\', JSON.stringify(config));\n  }, [config]);\n\n  // Find active vehicle details\n  const activeVehicle = vehicles.find(v => v.id === activeVehicleId) || vehicles[0];\n\n  // Action: Add Session Logger Record\n  const handleAddSession = (newSession: ChargingSession) => {\n    setSessions(prev => [newSession, ...prev]);\n    \n    // Automatically update Odometer on adding session if applicable\n    setVehicles(prevVehs => prevVehs.map(veh => {\n      if (veh.id === newSession.vehicleId) {\n        // Approximate added km based on loaded kWh energy\n        const addedKm = Math.round(newSession.energyKwh / (veh.efficiency / 1000));\n        return {\n          ...veh,\n          odometer: veh.odometer + addedKm,\n          batterySoC: Math.min(100, veh.batterySoC + 20) // top up SoC simulated\n        };\n      }\n      return veh;\n    }));\n\n    setCurrentTab(\'activity\');\n  };\n\n  // Action: Delete Session Log\n  const handleDeleteSession = (id: string) => {\n    setSessions(prev => prev.filter(s => s.id !== id));\n  };\n\n  // Action: Add custom registered Vehicle\n  const handleAddVehicle = (newVehicle: Vehicle) => {\n    setVehicles(prev => [...prev, newVehicle]);\n    setActiveVehicleId(newVehicle.id);\n  };\n\n  // Action: De-register vehicle\n  const handleDeleteVehicle = (id: string) => {\n    setVehicles(prev => prev.filter(v => v.id !== id));\n    // Fall back to tesla\n    setActiveVehicleId(\'tesla-3\');\n  };\n\n  // Reset entire activity logs\n  const handleClearSessions = () => {\n    localStorage.removeItem(\'volt_sessions\');\n    localStorage.removeItem(\'volt_vehicles\');\n    localStorage.removeItem(\'volt_config\');\n    setSessions([]);\n    setVehicles(INITIAL_VEHICLES);\n    setConfig(INITIAL_ASSUMPTIONS);\n    setActiveVehicleId(\'tesla-3\');\n  };\n\n  // Profile image asset\n  const userAvatar = \'https://lh3.googleusercontent.com/aida-public/AB6AXuDMBxaHoza_-xFrt3Dxc_K-6jjdlVNLUKiBpSS8fc1XFV8auGADAe8liCooyZ3F33y9DrjO6qsMIXqCIqFpqM0hxyaPVXtpFmUkQ5nMykTGBuGzgVuePU_UuDyEq6xDgnXx1Y2fL4cg31GKPHTIiPzLOMFBozacyC4FiqMBgDTho3JLshw9giJu5mUzruJv2wIO9AGWz_mkS5Fdb0yvTcFRNLgTMk7mifAhy9RVfalB2EUJJx3FOHSHCVeX8m65R0S7Wi7JX884PBV1\';\n\n  return (\n    <div className=\"bg-background text-on-background min-h-screen pb-28 relative font-sans selection:bg-primary/30 selection:text-white\">\n      \n      {/* State toggle check for \'log_charging\' view */}\n      {currentTab === \'log_charging\' ? (\n        <div className=\"flex justify-center py-4 bg-background px-container-padding-mobile\">\n          <LogCharging \n            activeVehicle={activeVehicle}\n            config={config}\n            onSave={handleAddSession}\n            onCancel={() => setCurrentTab(\'activity\')}\n          />\n        </div>\n      ) : (\n        <div className=\"max-w-xl mx-auto px-4 md:px-0\">\n          \n          {/* Top Custom App Bar Header */}\n          <header className=\"fixed top-0 left-0 w-full z-40 bg-surface/90 backdrop-blur-md border-b border-outline-variant/30 px-6 h-16 flex justify-between items-center transition-all\">\n            <div className=\"max-w-xl w-full mx-auto flex justify-between items-center\">\n              \n              <div \n                onClick={() => setCurrentTab(\'dashboard\')} \n                className=\"flex items-center gap-2.5 cursor-pointer select-none group\"\n              >\n                <Zap className=\"w-5 h-5 text-primary fill-none group-hover:scale-110 transition-transform\" />\n                <span className=\"font-sans text-xl font-black text-primary tracking-tight\">Volt</span>\n              </div>\n\n              <div className=\"flex items-center gap-4\">\n                <span className=\"text-xs font-mono text-on-surface-variant/70 hidden sm:inline-block\">\n                  Live \342\200\242 Synced\n                </span>\n                \n                {/* Profile Avatar click leads to settings */}\n                <div \n                  onClick={() => setCurrentTab(\'settings\')}\n                  className=\"w-8 h-8 rounded-full bg-surface-variant overflow-hidden border border-outline-variant hover:border-primary transition-all cursor-pointer shadow-md select-none\"\n                  title=\"View Profile Settings\"\n                >\n                  <img \n                    src={userAvatar} \n                    alt=\"Active User\" \n                    referrerPolicy=\"no-referrer\"\n                    className=\"w-full h-full object-cover\" \n                  />\n                </div>\n              </div>\n\n            </div>\n          </header>\n\n          {/* Hidden Web Desktop Nav Rail header spacing fallback */}\n          <nav className=\"hidden md:flex fixed top-0 left-1/2 -translate-x-1/2 h-16 items-center gap-8 z-50 pointer-events-auto\">\n            <button \n              onClick={() => setCurrentTab(\'dashboard\')}\n              className={`text-xs font-semibold uppercase tracking-wider outline-none cursor-pointer transition-colors ${\n                currentTab === \'dashboard\' ? \'text-primary border-b-2 border-primary h-full mt-1 pt-0.5\' : \'text-on-surface-variant hover:text-on-surface\'\n              }`}\n            >\n              Dashboard\n            </button>\n            <button \n              onClick={() => setCurrentTab(\'activity\')}\n              className={`text-xs font-semibold uppercase tracking-wider outline-none cursor-pointer transition-colors ${\n                currentTab === \'activity\' ? \'text-primary border-b-2 border-primary h-full mt-1 pt-0.5\' : \'text-on-surface-variant hover:text-on-surface\'\n              }`}\n            >\n              Activity\n            </button>\n            <button \n              onClick={() => setCurrentTab(\'vehicles\')}\n              className={`text-xs font-semibold uppercase tracking-wider outline-none cursor-pointer transition-colors ${\n                currentTab === \'vehicles\' ? \'text-primary border-b-2 border-primary h-full mt-1 pt-0.5\' : \'text-on-surface-variant hover:text-on-surface\'\n              }`}\n            >\n              Vehicles\n            </button>\n            <button \n              onClick={() => setCurrentTab(\'settings\')}\n              className={`text-xs font-semibold uppercase tracking-wider outline-none cursor-pointer transition-colors ${\n                currentTab === \'settings\' ? \'text-primary border-b-2 border-primary h-full mt-1 pt-0.5\' : \'text-on-surface-variant hover:text-on-surface\'\n              }`}\n            >\n              Settings\n            </button>\n          </nav>\n\n          {/* Main Content Body */}\n          <main className=\"pt-20 px-1\">\n            <div className=\"animate-fade-in duration-300\">\n              \n              {currentTab === \'dashboard\' && (\n                <Dashboard \n                  sessions={sessions}\n                  vehicles={vehicles}\n                  config={config}\n                  activeVehicle={activeVehicle}\n                  userAvatar={userAvatar}\n                />\n              )}\n\n              {currentTab === \'activity\' && (\n                <Activity \n                  sessions={sessions}\n                  vehicles={vehicles}\n                  config={config}\n                  onNavigateToLog={() => setCurrentTab(\'log_charging\')}\n                  onDeleteSession={handleDeleteSession}\n                />\n              )}\n\n              {currentTab === \'vehicles\' && (\n                <Vehicles \n                  vehicles={vehicles}\n                  activeVehicle={activeVehicle}\n                  onSelectVehicle={setActiveVehicleId}\n                  onAddVehicle={handleAddVehicle}\n                  onDeleteVehicle={handleDeleteVehicle}\n                  onNavigateToSettings={() => setCurrentTab(\'settings\')}\n                />\n              )}\n\n              {currentTab === \'settings\' && (\n                <Settings \n                  config={config}\n                  onSaveConfig={setConfig}\n                  onClearSessions={handleClearSessions}\n                  userEmail=\"Ujjwal.Ranjan@walmart.com\"\n                />\n              )}\n\n            </div>\n          </main>\n\n          {/* Fixed bottom navigation bar for mobile sizes */}\n          <nav className=\"fixed bottom-0 left-0 w-full z-50 flex justify-around items-center px-4 py-3 bg-surface-container border-t border-outline-variant/30 shadow-2xl rounded-t-xl md:hidden\">\n            \n            {/* Tab: Dashboard */}\n            <button \n              onClick={() => setCurrentTab(\'dashboard\')}\n              className={`flex flex-col items-center justify-center p-2 rounded-lg cursor-pointer select-none outline-none transition-all ${\n                currentTab === \'dashboard\' \n                  ? \'text-primary bg-primary-container/10 px-4 py-2 scale-95 font-semibold\' \n                  : \'text-on-surface-variant hover:text-primary\'\n              }`}\n            >\n              <LayoutDashboard className=\"w-4 h-4 mb-1\" />\n              <span className=\"text-[10px] uppercase font-bold tracking-wider leading-none\">Dashboard</span>\n            </button>\n\n            {/* Tab: Activity */}\n            <button \n              onClick={() => setCurrentTab(\'activity\')}\n              className={`flex flex-col items-center justify-center p-2 rounded-lg cursor-pointer select-none outline-none transition-all ${\n                currentTab === \'activity\' \n                  ? \'text-primary bg-primary-container/10 px-4 py-2 scale-95 font-semibold\' \n                  : \'text-on-surface-variant hover:text-primary\'\n              }`}\n            >\n              <ReceiptText className=\"w-4 h-4 mb-1\" />\n              <span className=\"text-[10px] uppercase font-bold tracking-wider leading-none\">Activity</span>\n            </button>\n\n            {/* Tab: Vehicles */}\n            <button \n              onClick={() => setCurrentTab(\'vehicles\')}\n              className={`flex flex-col items-center justify-center p-2 rounded-lg cursor-pointer select-none outline-none transition-all ${\n                currentTab === \'vehicles\' \n                  ? \'text-primary bg-primary-container/10 px-4 py-2 scale-95 font-semibold\' \n                  : \'text-on-surface-variant hover:text-primary\'\n              }`}\n            >\n              <CarFront className=\"w-4 h-4 mb-1\" />\n              <span className=\"text-[10px] uppercase font-bold tracking-wider leading-none\">Vehicles</span>\n            </button>\n\n            {/* Tab: Settings */}\n            <button \n              onClick={() => setCurrentTab(\'settings\')}\n              className={`flex flex-col items-center justify-center p-2 rounded-lg cursor-pointer select-none outline-none transition-all ${\n                currentTab === \'settings\' \n                  ? \'text-primary bg-primary-container/10 px-4 py-2 scale-95 font-semibold\' \n                  : \'text-on-surface-variant hover:text-primary\'\n              }`}\n            >\n              <SettingsIcon className=\"w-4 h-4 mb-1\" />\n              <span className=\"text-[10px] uppercase font-bold tracking-wider leading-none\">Settings</span>\n            </button>\n\n          </nav>\n\n        </div>\n      )}\n\n    </div>\n  );\n}\n"
    }
